# .env.local — used by `npm run dev` and `npm run build`/`npm start`.
# Point this at the Supabase instance you want the *running app* to talk to
# (typically the hosted Supabase Cloud project).
#
# For automated tests use `.env.test` instead — it is loaded explicitly by
# vitest.config.ts (db tests) and playwright.config.ts (e2e tests) and is
# pinned to the local `supabase start` Docker container.
#
# To run the dev server against the same local container the tests use:
#   npm run dev:local       # loads .env.test, then runs `next dev`

# --- Supabase project (REQUIRED) -----------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App URLs (REQUIRED for emails / password reset / inbound links) -----
# Public origin of the running Next.js app. Used by auth emails, the inbound
# email parser, and admin pages that build absolute URLs.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# Optional — overrides NEXT_PUBLIC_APP_URL specifically for CSAT email links.
# NEXT_PUBLIC_SITE_URL=

# --- AI / LLM (optional env-level fallback) ----------------------------------
# Used when no API key is configured in Admin → AI. If a key is later saved
# through the admin UI it is stored in Supabase Vault and takes precedence.
# AI_PROVIDER=openai             # openai | anthropic | custom
# AI_API_KEY=                    # provider API key
# AI_MODEL=                      # model name, e.g. gpt-4o or claude-3-5-sonnet-20241022
# AI_CUSTOM_ENDPOINT_URL=        # only when AI_PROVIDER=custom

# --- Cron / webhook secrets (REQUIRED in production) ---------------------
# Shared secret for the SLA + notifications cron endpoints. If unset, the
# routes fall back to SUPABASE_SERVICE_ROLE_KEY (acceptable in dev only).
# Generate a random 32+ char token, e.g.: openssl rand -hex 32
CRON_SECRET=
# Optional — separate secret for the inbound-email webhook. Falls back to
# CRON_SECRET when unset.
# INBOUND_EMAIL_WEBHOOK_SECRET=
