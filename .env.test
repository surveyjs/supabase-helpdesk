# .env.test — pinned to the local `supabase start` Docker container.
# Loaded automatically by:
#   - vitest.config.ts            (npm run test:db)
#   - playwright.config.ts        (npm run test:e2e — also forwarded into
#                                  the spawned Next.js webServer)
#   - npm run dev:local           (manual dev against the local container)
#
# The keys below are the deterministic anon/service keys that Supabase CLI
# always generates for `supabase start`. They are safe to commit and must
# match exactly so CI can run tests without secrets.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Local app origin for tests that need an absolute URL (emails, etc.).
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# CRON_SECRET is intentionally unset for tests — the cron routes fall back
# to SUPABASE_SERVICE_ROLE_KEY in that case, which the test harness already
# has access to.
