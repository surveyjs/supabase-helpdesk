{
  "themeName": "helpdesk",
  "colorPalette": "light",
  "isPanelless": true,
  "cssVariables": {
    "--sjs-font-family": "Arial, Helvetica, sans-serif",
    "--sjs-corner-radius": "6px",
    "--sjs-base-unit": "8px",

    "--sjs-primary-backcolor": "#2563eb",
    "--sjs-primary-backcolor-light": "rgba(37, 99, 235, 0.1)",
    "--sjs-primary-backcolor-dark": "#1d4ed8",
    "--sjs-primary-forecolor": "#ffffff",
    "--sjs-primary-forecolor-light": "rgba(255, 255, 255, 0.5)",

    "--sjs-general-backcolor": "#ffffff",
    "--sjs-general-backcolor-dark": "#f9fafb",
    "--sjs-general-backcolor-dim": "#ffffff",
    "--sjs-general-backcolor-dim-light": "#ffffff",
    "--sjs-general-backcolor-dim-dark": "#f9fafb",
    "--sjs-general-forecolor": "#111827",
    "--sjs-general-forecolor-light": "#6b7280",
    "--sjs-general-dim-forecolor": "#374151",
    "--sjs-general-dim-forecolor-light": "#6b7280",

    "--sjs-secondary-backcolor": "#f3f4f6",
    "--sjs-secondary-backcolor-light": "rgba(243, 244, 246, 0.5)",
    "--sjs-secondary-backcolor-semi-light": "rgba(243, 244, 246, 0.75)",
    "--sjs-secondary-forecolor": "#374151",
    "--sjs-secondary-forecolor-light": "rgba(55, 65, 81, 0.5)",

    "--sjs-shadow-small": "none",
    "--sjs-shadow-small-reset": "none",
    "--sjs-shadow-medium": "none",
    "--sjs-shadow-large": "none",
    "--sjs-shadow-inner": "inset 0 0 0 1px #d1d5db",
    "--sjs-shadow-inner-reset": "none",

    "--sjs-border-default": "#e5e7eb",
    "--sjs-border-light": "#f3f4f6",
    "--sjs-border-inside": "#e5e7eb",

    "--sjs-special-red": "#dc2626",
    "--sjs-special-red-light": "rgba(220, 38, 38, 0.1)",
    "--sjs-special-red-forecolor": "#ffffff",
    "--sjs-special-green": "#16a34a",
    "--sjs-special-green-light": "rgba(22, 163, 74, 0.1)",
    "--sjs-special-green-forecolor": "#ffffff",
    "--sjs-special-blue": "#2563eb",
    "--sjs-special-blue-light": "rgba(37, 99, 235, 0.1)",
    "--sjs-special-blue-forecolor": "#ffffff",
    "--sjs-special-yellow": "#ca8a04",
    "--sjs-special-yellow-light": "rgba(202, 138, 4, 0.1)",
    "--sjs-special-yellow-forecolor": "#ffffff",

    "--sjs-article-font-default-textDecoration": "none",
    "--sjs-article-font-default-fontWeight": "400",
    "--sjs-article-font-default-fontStyle": "normal",
    "--sjs-article-font-default-fontStretch": "normal",
    "--sjs-article-font-default-letterSpacing": "0",
    "--sjs-article-font-default-lineHeight": "1.5",
    "--sjs-article-font-default-paragraphIndent": "0px",
    "--sjs-article-font-default-textCase": "none",

    "--sjs-font-questiontitle-family": "Arial, Helvetica, sans-serif",
    "--sjs-font-questiontitle-weight": "500",
    "--sjs-font-questiontitle-color": "#111827",
    "--sjs-font-questiontitle-size": "14px",

    "--sjs-font-questiondescription-family": "Arial, Helvetica, sans-serif",
    "--sjs-font-questiondescription-weight": "400",
    "--sjs-font-questiondescription-color": "#6b7280",
    "--sjs-font-questiondescription-size": "13px",

    "--sjs-font-editorfont-family": "Arial, Helvetica, sans-serif",
    "--sjs-font-editorfont-weight": "400",
    "--sjs-font-editorfont-color": "#111827",
    "--sjs-font-editorfont-placeholdercolor": "#9ca3af",
    "--sjs-font-editorfont-size": "14px",

    "--sjs-font-pagetitle-family": "Arial, Helvetica, sans-serif",
    "--sjs-font-pagetitle-weight": "600",
    "--sjs-font-pagetitle-color": "#111827",
    "--sjs-font-pagetitle-size": "16px",

    "--sjs-font-pagedescription-family": "Arial, Helvetica, sans-serif",
    "--sjs-font-pagedescription-weight": "400",
    "--sjs-font-pagedescription-color": "#6b7280",
    "--sjs-font-pagedescription-size": "13px",

    "--sjs-font-surveytitle-family": "Arial, Helvetica, sans-serif",
    "--sjs-font-surveytitle-weight": "700",
    "--sjs-font-surveytitle-color": "#111827",
    "--sjs-font-surveytitle-size": "20px",

    "--sjs-questionpanel-backcolor": "transparent",
    "--sjs-questionpanel-hovercolor": "transparent",
    "--sjs-questionpanel-cornerRadius": "0px",
    "--sjs-editor-background": "#ffffff",
    "--sjs-editorpanel-backcolor": "transparent",
    "--sjs-editorpanel-hovercolor": "#f9fafb",
    "--sjs-editorpanel-cornerRadius": "6px"
  }
}
